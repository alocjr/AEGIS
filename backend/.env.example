# Copie para .env e preencha com seus valores. NUNCA commite o .env com dados reais.

# MongoDB (ex.: Atlas)
MONGODB_URI=mongodb+srv://:@general.mxf2w.mongodb.net/?retryWrites=true&w=majority&appName=Valorian4Future&tlsAllowInvalidCertificates=true
MONGODB_DB_NAME=aegis

# JWT (gere uma chave forte, ex.: openssl rand -hex 32)
JWT_SECRET_KEY=sua_chave_secreta_aqui_minimo_32_caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# CORS (origens permitidas separadas por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Reset de senha
PASSWORD_RESET_EXPIRE_MINUTES=30
# URL do frontend (link no email de reset)
APP_BASE_URL=http://localhost:5173

# SMTP (envio do email de reset de senha)
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=seu_email@exemplo.com
SMTP_PASSWORD=sua_senha_smtp
SMTP_FROM=seu_email@exemplo.com
SMTP_USE_TLS=true
# Use SMTP_USE_SSL=true para porta 465 (mutuamente exclusivo com TLS em alguns provedores)
SMTP_USE_SSL=false
